<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- 🔷 TITLE -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ozora PCR"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#2D3436"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 🔷 SUBTITLE -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pilih menunya"
        android:textSize="14sp"
        android:textColor="#636E72"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 🔷 CARD MENU -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMenu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- BUTTON PERTEMUAN 4 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToFourth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pertemuan 4"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:backgroundTint="#6C5CE7"
                app:cornerRadius="14dp"/>

            <!-- BUTTON PERTEMUAN 5 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToFifth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pertemuan 5"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:backgroundTint="#00B894"
                android:layout_marginTop="16dp"
                app:cornerRadius="14dp"/>

            <!-- BUTTON PERTEMUAN 7 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToSeventh"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pertemuan 7"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:backgroundTint="#0984E3"
                android:layout_marginTop="16dp"
                app:cornerRadius="14dp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- 🔷 LOGOUT BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:backgroundTint="#D63031"
        android:layout_margin="24dp"
        app:cornerRadius="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
