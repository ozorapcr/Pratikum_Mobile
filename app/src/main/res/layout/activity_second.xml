<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFB6C1"
    android:padding="24dp"
    tools:context=".Home.pertemuan_2.SecondActivity">

    <!-- Soft Pink Gradient Background Layers -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFC0CB"
        android:alpha="0.8"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFD1DC"
        android:alpha="0.6"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFE4E1"
        android:alpha="0.4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnSubmit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        android:text="SUBMIT  ✨"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="normal"
        android:fontFamily="sans-serif-medium"
        android:backgroundTint="#FF69B4"
        android:letterSpacing="0.05"
        android:paddingLeft="40dp"
        android:paddingRight="40dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:stateListAnimator="@null"
        android:elevation="8dp"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/inputNama"
        app:layout_constraintVertical_bias="0.02" />

    <TextView
        android:id="@+id/textNama"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="📝  Nama Lengkap"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="normal"
        android:fontFamily="serif"
        android:letterSpacing="0.03"
        android:shadowColor="#80FF69B4"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        android:drawablePadding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView3" />

    <EditText
        android:id="@+id/inputNama"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="✏️  Masukkan nama lengkap"
        android:textColorHint="#FFB6C1"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:fontFamily="sans-serif"
        android:typeface="normal"
        android:background="@android:drawable/editbox_background"
        android:backgroundTint="#80FFFFFF"
        android:padding="16dp"
        android:maxLines="1"
        android:inputType="textPersonName"
        android:alpha="0.95"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textNama" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="120dp"
        android:text="🌸  Welcome Back  🌸"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="normal"
        android:fontFamily="serif"
        android:gravity="center"
        android:letterSpacing="0.05"
        android:shadowColor="#4DFF69B4"
        android:shadowDx="4"
        android:shadowDy="4"
        android:shadowRadius="6"
        android:alpha="0.98"
        android:lineSpacingExtra="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Soft Pink Decorative Circles -->
    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="#20FFB6C1"
        android:layout_marginTop="-120dp"
        android:layout_marginEnd="-100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="#20FFC0CB"
        android:layout_marginBottom="-150dp"
        android:layout_marginStart="-120dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="#20FFD1DC"
        android:layout_marginBottom="80dp"
        android:layout_marginEnd="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:background="#20FFE4E1"
        android:layout_marginTop="100dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="#20FF99CC"
        android:layout_marginTop="200dp"
        android:layout_marginEnd="50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="#20FFAABB"
        android:layout_marginBottom="150dp"
        android:layout_marginStart="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>